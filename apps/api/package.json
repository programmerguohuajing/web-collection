{
  "name": "@web-collection/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "start": "pm2 start ../../ecosystem.config.cjs --only web-collection-api --env production",
    "start:pm2": "pm2 start ../../ecosystem.config.cjs --only web-collection-api --env production",
    "restart:pm2": "pm2 restart web-collection-api --update-env",
    "stop:pm2": "pm2 stop web-collection-api",
    "db:init": "node src/scripts/init-db.js",
    "test": "node --test --test-concurrency=1 ../../test/*.test.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.16.3",
    "source-map-js": "1.2.1"
  }
}
